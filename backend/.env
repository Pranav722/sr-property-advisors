NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/sr-property?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=sr_property_advisors-JWT_SECRET
JWT_EXPIRE=30d

# Cloudinary Storage
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
